# ─── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────
# DO NOT commit .env to git

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (get from https://cloud.mongodb.com → Connect → Drivers)
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/examedge
MONGODB_URI=mongodb://localhost:27017/examedge

# Redis (optional – leave blank to disable caching in dev)
# Get free Redis at https://redis.io/try-free/ or use local redis-server
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# ── NEWS APIs ──────────────────────────────────────────────────────────────────
# NewsAPI (free tier = 100 req/day): https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# GNews (free tier = 100 req/day): https://gnews.io/
GNEWS_KEY=your_gnews_key_here

# ── AI ─────────────────────────────────────────────────────────────────────────
# Anthropic API: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── PAYMENTS ───────────────────────────────────────────────────────────────────
# Razorpay: https://dashboard.razorpay.com/ → Settings → API Keys
# Use TEST keys during development (start with rzp_test_)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Subscription price in paise (100 paise = ₹1), so ₹19 = 1900
SUBSCRIPTION_AMOUNT=1900
SUBSCRIPTION_CURRENCY=INR
SUBSCRIPTION_DAYS=180

# ── SMS OTP (optional for dev – skip for email OTP) ───────────────────────────
# MSG91: https://msg91.com/
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=EXAMEG

# ── FRONTEND ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
